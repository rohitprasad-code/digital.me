# Digital Me - API & Frontend Configurations
DIGITAL_ME_API_URL=http://localhost:7001/api/chat

# Neon Database (Postgres)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# LLM Providers Configuration
# Choices: "ollama" (local), "gemini" (cloud), "groq" (cloud)
LLM_PROVIDER=ollama

# Ollama Settings (Local AI)
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Gemini Settings
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_API_KEY=your_gemini_api_key_here

# Groq Settings (Required for tool calling loop)
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=your_groq_api_key_here

# Legacy Integration Credentials (Deprecated; config moved to mcp_config.json)
# GITHUB_USERNAME=
# GITHUB_TOKEN=
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REFRESH_TOKEN=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
