{
  "mcpServers": {
    "strava": {
      "command": "npx",
      "args": [
        "-y",
        "@r-huijts/strava-mcp-server"
      ],
      "env": {
        "STRAVA_CLIENT_ID": "199188"
      },
      "ingest": [
        {
          "tool": "get_athlete",
          "args": {},
          "source": "profile",
          "title": "Strava Athlete Profile"
        },
        {
          "tool": "get_activities",
          "args": { "limit": 10 },
          "source": "activities",
          "title": "Recent Activities"
        }
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {},
      "ingest": [
        {
          "tool": "list_repositories",
          "args": {},
          "source": "repos",
          "title": "GitHub Repositories"
        }
      ]
    }
  }
}
